# Copy this file to .env and replace values with your own secrets.
# This repository ignores .env files so secrets stay out of version control.

PASSWORD=your_password_here
SESSION_SECRET=your_session_secret_here

# Optional Supabase client values. The app already uses public fallback defaults.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key
