# Dependencies (will be installed fresh inside Docker)
**/node_modules
**/.pnpm-store
**/.npm
**/.yarn

# Build outputs (will be built fresh inside Docker)
**/dist
**/.next
**/.turbo
**/.cache
**/.parcel-cache
artifacts/app/dist
tmp
out-tsc
*.tsbuildinfo

# Dev / editor files
.git
.gitignore
.env*
*.local
.agents/
.vscode/
.vercel/

# Replit-specific files
.replit
replit.nix
.config/
.upm/
.cache/
attached_assets/

# Log files
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Test and CI
coverage/
.nyc_output/

# Large media / assets that are not needed for the build
*.zip
*.mp4
*.mov
*.psd
*.ai
